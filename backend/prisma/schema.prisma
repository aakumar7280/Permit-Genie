// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String   @unique
  password    String
  phoneNumber String?
  companyName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  projects      Project[]
  applications  Application[]
  savedPermits  SavedPermit[]
  
  @@map("users")
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  location    String?
  status      String   @default("draft") // draft, active, completed, cancelled
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permits     Permit[]
  
  @@map("projects")
}

model Permit {
  id          Int      @id @default(autoincrement())
  name        String
  type        String   // building, event, business, etc.
  status      String   @default("pending") // pending, approved, rejected, in_review
  description String?
  projectId   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@map("permits")
}

// Toronto Government Permits - for search and reference
model TorontoPermit {
  id          Int      @id @default(autoincrement())
  csvId       Int      // Original ID from CSV
  name        String
  category    String   // Business, Building, Vehicle, etc.
  description String
  url         String?
  keywords    String?  // For search optimization
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  applications  Application[]
  savedByUsers   SavedPermit[]
  
  @@index([category])
  @@index([name])
  @@map("toronto_permits")
}

// User permit applications
model Application {
  id              Int      @id @default(autoincrement())
  userId          Int
  permitId        Int      // FK to TorontoPermit
  status          String   @default("draft") // draft, submitted, in_review, approved, rejected
  
  // ── Step 1: Applicant Information ──
  applicantName       String
  applicantEmail      String
  applicantPhone      String?
  applicantDateOfBirth String?   // YYYY-MM-DD
  mailingAddress      String?   // Applicant's mailing address (if different from property)
  
  // ── Step 2: Property / Location Details ──
  propertyAddress     String?   // Municipal street address
  propertyUnit        String?   // Unit / Suite number
  propertyCity        String    @default("Toronto")
  propertyPostalCode  String?
  propertyWard        String?   // City of Toronto ward
  propertyLegalDescription String? // Lot, plan, etc.
  propertyType        String?   // Residential, Commercial, Industrial, Mixed-Use
  
  // ── Step 3: Business / Entity Details ──
  businessName        String?   // Legal business name
  businessTradeName   String?   // Operating / trade name (DBA)
  businessType        String?   // Sole Proprietorship, Partnership, Corporation, Non-Profit
  businessNumber      String?   // Ontario Business Number (BN / HST number)
  incorporationNumber String?   // Corporation number if applicable
  businessPhone       String?   // Main business phone
  businessEmail       String?   // Business contact email
  
  // ── Step 4: Project / Work Scope ──
  projectDescription  String?   // Detailed description of proposed work
  projectPurpose      String?   // Purpose: New Construction, Renovation, Change of Use, etc.
  projectStartDate    String?   // Intended start date
  projectEndDate      String?   // Expected completion date
  estimatedCost       String?   // Estimated total project cost ($)
  squareFootage       String?   // Area of work in sq ft
  numberOfStoreys     String?   // Number of storeys (building permits)
  contractorName      String?   // Licensed contractor name
  contractorPhone     String?   // Contractor contact
  contractorLicense   String?   // Contractor licence number
  architectEngineer   String?   // Architect / engineer name (if applicable)
  
  // ── Step 5: Additional / Compliance ──
  zoningConfirmed     Boolean   @default(false) // Has applicant confirmed zoning compliance?
  insuranceProvider   String?   // Liability insurance provider
  insurancePolicyNumber String? // Policy number
  previousPermitNumber String?  // Reference to prior related permit (if any)
  additionalNotes     String?   // Free-form notes
  
  submittedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  permit          TorontoPermit @relation(fields: [permitId], references: [id])
  
  @@index([userId])
  @@index([permitId])
  @@index([status])
  @@map("applications")
}

// Saved / bookmarked permits (not yet applied)
model SavedPermit {
  id        Int      @id @default(autoincrement())
  userId    Int
  permitId  Int
  createdAt DateTime @default(now())

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  permit TorontoPermit @relation(fields: [permitId], references: [id], onDelete: Cascade)

  @@unique([userId, permitId])
  @@index([userId])
  @@map("saved_permits")
}
