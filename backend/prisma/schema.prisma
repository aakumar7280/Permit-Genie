// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String   @unique
  password    String
  phoneNumber String?
  companyName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations for future features
  projects    Project[]
  
  @@map("users")
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  location    String?
  status      String   @default("draft") // draft, active, completed, cancelled
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permits     Permit[]
  
  @@map("projects")
}

model Permit {
  id          Int      @id @default(autoincrement())
  name        String
  type        String   // building, event, business, etc.
  status      String   @default("pending") // pending, approved, rejected, in_review
  description String?
  projectId   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@map("permits")
}

// Toronto Government Permits - for search and reference
model TorontoPermit {
  id          Int      @id @default(autoincrement())
  csvId       Int      // Original ID from CSV
  name        String
  category    String   // Business, Building, Vehicle, etc.
  description String
  url         String?
  keywords    String?  // For search optimization
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([category])
  @@index([name])
  @@map("toronto_permits")
}
